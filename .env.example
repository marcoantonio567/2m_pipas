# Supabase settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Django settings
SECRET_KEY=replace_with_a_secure_random_secret
DEBUG=False
ALLOWED_HOSTS=.vercel.app,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://your-project.vercel.app

# Use postgres for Supabase or sqlite for the local db.sqlite3 file.
DATABASE_ENGINE=postgres

# Supabase Postgres connection
# Prefer SUPABASE_DB_URL on Vercel. For Supabase pooler on port 6543,
# the user is usually postgres.<project-ref>, not only postgres.
# URL-encode special password characters, for example @ as %40 and # as %23.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:url_encoded_password@aws-1-us-west-2.pooler.supabase.com:6543/postgres
# Optional fallback if your host provides DATABASE_URL automatically.
DATABASE_URL=postgresql://user:url_encoded_password@host:port/database
SUPABASE_DB_HOST=aws-1-us-west-2.pooler.supabase.com
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your_database_password
SUPABASE_DB_PORT=6543
